{
  "expo": {
    "name": "Entrelinhas",
    "slug": "Entrelinhas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/launcher-icon-512x512.png",
    "scheme": "entrelinhasnative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobile.Entrelinhas",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/launcher-icon-192x192.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mobile.Entrelinhas"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/launcher-icon-192x192.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/launcher-icon-512x512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d00521fa-cadb-4eef-b0cd-01de7524b747"
      }
    }
  }
}
